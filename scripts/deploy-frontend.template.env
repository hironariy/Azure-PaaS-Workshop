# =============================================================================
# Frontend Deployment Configuration Template
# =============================================================================
# Copy this file to the Cloud Shell state directory and fill in your values:
#   mkdir -p "$HOME/clouddrive/paas-workshop"
#   cp scripts/deploy-frontend.template.env "$HOME/clouddrive/paas-workshop/deploy-frontend.local.env"
#
# This file is used by scripts/deploy-frontend.sh
# The .local.env file is ignored by Git when created in the legacy repo-local path.
# =============================================================================

# Entra ID Tenant ID (from Azure Portal > Entra ID > Overview)
ENTRA_TENANT_ID="your-tenant-id-here"

# Frontend SPA Application Client ID (from Entra ID > App registrations)
ENTRA_FRONTEND_CLIENT_ID="your-frontend-client-id-here"

# Backend API Application Client ID (from Entra ID > App registrations)
ENTRA_BACKEND_CLIENT_ID="your-backend-client-id-here"
